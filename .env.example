# 测量仪器管理系统 — 环境变量配置
# 复制此文件为 .env 并填写实际值

# 应用密钥 (生产环境务必修改为随机字符串)
SECRET_KEY=measure-instrument-system-secret-key-2026

# 数据库连接
DATABASE_URL=sqlite:///./app.db
# 生产环境使用 PostgreSQL:
# DATABASE_URL=postgresql://postgres:your_password@db:5432/measure_instruments

# Redis
REDIS_URL=redis://localhost:6379/0

# 调试模式 (生产环境设为 False)
DEBUG=True

# 上传文件目录
UPLOAD_DIR=./uploads

# JWT 配置
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 检定到期预警天数
CALIBRATION_WARN_DAYS=30,15,7

# PostgreSQL 密码 (Docker Compose 使用)
POSTGRES_PASSWORD=change-me-in-production
